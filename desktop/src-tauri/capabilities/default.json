{
  "$schema": "../gen/schemas/desktop-schema.json",
  "identifier": "default",
  "description": "Default capabilities for the Ralph Meet desktop client",
  "windows": [
    "main",
    "updater"
  ],
  "permissions": [
    "core:default",
    "core:app:allow-default-window-icon",
    "core:image:default",
    "core:tray:allow-get-by-id",
    "core:tray:allow-set-icon",
    "core:tray:allow-set-tooltip",
    "core:window:allow-set-overlay-icon",
    "core:window:allow-request-user-attention",
    "opener:default",
    "deep-link:default",
    "deep-link:allow-register",
    "notification:default",
    "window-state:default",
    "updater:default",
    "process:allow-restart",
    "autostart:default",
    "allow-get-native-audio-devices",
    "allow-get-native-video-devices",
    "allow-get-screen-sources",
    "allow-get-source-thumbnail",
    "allow-probe-hardware-video-encoders",
    "allow-start-native-screen-share",
    "allow-handle-sdp-answer",
    "allow-wait-native-screen-share-connected",
    "allow-stop-native-screen-share",
    "allow-update-native-screen-quality",
    "allow-get-native-screen-share-stats",
    "allow-start-preview-loopback",
    "allow-handle-preview-loopback-answer",
    "allow-handle-preview-loopback-ice-candidate",
    "allow-stop-preview-loopback",
    "allow-get-hardware-acceleration",
    "allow-set-hardware-acceleration",
    "allow-set-close-to-tray",
    "allow-set-start-minimized",
    "allow-set-title-bar-dark-mode",
    "allow-fetch-update",
    "allow-install-update"
  ]
}
