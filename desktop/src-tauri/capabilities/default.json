{
  "$schema": "../gen/schemas/desktop-schema.json",
  "identifier": "default",
  "description": "Default capabilities for the Ralph Meet desktop client",
  "windows": [
    "main"
  ],
  "permissions": [
    "core:default",
    "shell:allow-open",
    "deep-link:default",
    "notification:default",
    "clerk:default",
    {
      "identifier": "http:default",
      "allow": [
        {
          "url": "https://*"
        }
      ]
    },
    "window-state:default",
    "updater:default",
    "process:allow-restart",
    "autostart:default"
  ]
}