{
  "$schema": "https://schema.tauri.app/config/2",
  "productName": "Ralph Meet",
  "version": "0.1.0",
  "identifier": "dev.jontitor.ralph-meet",
  "build": {
    "frontendDist": "../dist/client",
    "devUrl": "http://localhost:1420",
    "beforeDevCommand": "npm run dev:vite",
    "beforeBuildCommand": "npm run build:vite"
  },
  "app": {
    "windows": [
      {
        "title": "Ralph Meet",
        "width": 1280,
        "height": 800,
        "minWidth": 940,
        "minHeight": 560,
        "resizable": true,
        "fullscreen": false,
        "decorations": true,
        "center": true,
        "useHttpsScheme": true,
        "additionalBrowserArgs": "--disable-features=msWebOOUI,msPdfOOUI,msSmartScreenProtection --enable-features=WebRtcAllowInputVolumeAdjustment"
      }
    ],
    "security": {
      "csp": "default-src 'self' 'unsafe-inline' 'unsafe-eval'; connect-src 'self' https://ralph-meet.jontitor.workers.dev wss://ralph-meet.jontitor.workers.dev https://*.clerk.accounts.dev https://api.clerk.dev https://clerk.clerk.com https://*.clerk.com https://github.com https://*.github.com https://api.github.com; img-src 'self' https: data: blob:; media-src 'self' https: blob:; font-src 'self' https://fonts.googleapis.com https://fonts.gstatic.com; style-src 'self' 'unsafe-inline' https://fonts.googleapis.com; frame-src https://*.clerk.accounts.dev https://*.clerk.com;"
    }
  },
  "bundle": {
    "active": true,
    "targets": "all",
    "createUpdaterArtifacts": true,
    "icon": [
      "icons/32x32.png",
      "icons/128x128.png",
      "icons/128x128@2x.png",
      "icons/icon.icns",
      "icons/icon.ico"
    ]
  },
  "plugins": {
    "shell": {
      "open": true
    },
    "deep-link": {
      "desktop": {
        "schemes": [
          "ralphmeet"
        ]
      }
    },
    "updater": {
      "pubkey": "dW50cnVzdGVkIGNvbW1lbnQ6IG1pbmlzaWduIHB1YmxpYyBrZXk6IDdDQjE5NTNGMTg4QUZFN0UKUldSKy9vb1lQNVd4Zko5dHAxZGd4UElwODFZamxZb1p1dWoyM05KZStrTW5mNHZoaWRwR1VvdXgK",
      "endpoints": [
        "https://github.com/115jon/ralph-meet/releases/latest/download/latest.json"
      ]
    }
  }
}