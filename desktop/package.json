{
  "name": "ralph-meet-desktop",
  "version": "1.13.0",
  "private": true,
  "type": "module",
  "scripts": {
    "tauri": "tauri",
    "dev": "tauri dev",
    "dev:deployed:script": "powershell -ExecutionPolicy Bypass -File ./scripts/dev-deployed.ps1",
    "prod:deployed:script": "powershell -ExecutionPolicy Bypass -File ./scripts/prod-deployed.ps1 -NoHook",
    "prod:deployed:script:hook": "powershell -ExecutionPolicy Bypass -File ./scripts/prod-deployed.ps1",
    "prod:deployed:script:wgc": "powershell -ExecutionPolicy Bypass -File ./scripts/prod-deployed.ps1 -Wgc",
    "dev:deployed": "tauri dev --config src-tauri/tauri.deployed.conf.json",
    "dev:deployed:hook": "tauri dev --config src-tauri/tauri.deployed.conf.json --features game-capture-hook",
    "dev:vite": "vite",
    "dev:vite:deployed": "vite --mode deployed",
    "build:vite": "vite build",
    "build:vite:deployed": "vite build --mode deployed",
    "build": "pnpm run build:vite && cargo tauri build",
    "build:deployed": "cargo tauri build --config src-tauri/tauri.deployed.conf.json",
    "bundle:deployed": "cargo tauri bundle --config src-tauri/tauri.deployed.conf.json",
    "preview": "tauri dev --release"
  },
  "devDependencies": {
    "@tailwindcss/vite": "^4.0.0",
    "@tauri-apps/cli": "^2.10.0",
    "@vitejs/plugin-react": "^4.5.2",
    "vite": "^7.0.0"
  },
  "dependencies": {
    "@kova/react": "workspace:*",
    "@tauri-apps/api": "^2.5.0",
    "@tauri-apps/plugin-autostart": "^2.5.1",
    "@tauri-apps/plugin-deep-link": "^2.2.0",
    "@tauri-apps/plugin-notification": "^2.3.3",
    "@tauri-apps/plugin-process": "^2.3.1",
    "@tauri-apps/plugin-shell": "^2.2.0",
    "@tauri-apps/plugin-updater": "^2.10.0"
  }
}
