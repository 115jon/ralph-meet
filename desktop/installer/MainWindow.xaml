<Window x:Class="Installer.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Ralph Meet Setup" Height="300" Width="300"
        WindowStyle="None" AllowsTransparency="True" Background="Transparent"
        WindowStartupLocation="CenterScreen"
        Topmost="True" ShowInTaskbar="True" ResizeMode="NoResize">

    <Window.Resources>
        <!-- Breathing Animation -->
        <Storyboard x:Key="BreatheAnimation" RepeatBehavior="Forever" AutoReverse="True">
            <DoubleAnimation Storyboard.TargetName="LogoScale" Storyboard.TargetProperty="ScaleX" From="1" To="1.05" Duration="0:0:1.5" />
            <DoubleAnimation Storyboard.TargetName="LogoScale" Storyboard.TargetProperty="ScaleY" From="1" To="1.05" Duration="0:0:1.5" />
            <DoubleAnimation Storyboard.TargetName="LogoGlow" Storyboard.TargetProperty="BlurRadius" From="10" To="25" Duration="0:0:1.5" />
            <DoubleAnimation Storyboard.TargetName="LogoGlow" Storyboard.TargetProperty="Opacity" From="0.5" To="0.8" Duration="0:0:1.5" />
        </Storyboard>

        <!-- Loading Bar sliding -->
        <Storyboard x:Key="LoadingAnimation" RepeatBehavior="Forever">
            <DoubleAnimation Storyboard.TargetName="LoadingBarTranslate" Storyboard.TargetProperty="X" From="-100" To="200" Duration="0:0:1.5" />
        </Storyboard>
    </Window.Resources>

    <Border Background="#1E1F22" CornerRadius="8" Margin="10"
            BorderBrush="#383A40" BorderThickness="1">
        <Border.Effect>
            <DropShadowEffect BlurRadius="15" ShadowDepth="2" Opacity="0.6" Color="Black" />
        </Border.Effect>
        <Grid>
            <!-- Logo container -->
            <Image x:Name="LogoImage" Source="pack://application:,,,/Assets/logo.png" Width="96" Height="96" VerticalAlignment="Center" HorizontalAlignment="Center" RenderTransformOrigin="0.5,0.5">
                <Image.Effect>
                    <!-- Cyan/Teal glow effect (mimics conn-glow) -->
                    <DropShadowEffect x:Name="LogoGlow" Color="#00BFFF" BlurRadius="20" ShadowDepth="0" Opacity="0.6" />
                </Image.Effect>
                <Image.RenderTransform>
                    <ScaleTransform x:Name="LogoScale" ScaleX="1" ScaleY="1" />
                </Image.RenderTransform>
            </Image>

            <!-- Installer text -->
            <TextBlock x:Name="StatusText" Text="STARTING..." FontSize="12" Foreground="#80848E" FontFamily="Segoe UI" FontWeight="Bold"
                       HorizontalAlignment="Center" VerticalAlignment="Bottom" Margin="0,0,0,40" />

            <!-- Loading Bar -->
            <Border Width="160" Height="4" Background="#2B2D31" CornerRadius="2"
                    VerticalAlignment="Bottom" HorizontalAlignment="Center" Margin="0,0,0,25" ClipToBounds="True">
                <Grid>
                    <Rectangle Fill="#00BFFF" Width="80" Height="4" HorizontalAlignment="Left" RadiusX="2" RadiusY="2">
                        <Rectangle.RenderTransform>
                            <TranslateTransform x:Name="LoadingBarTranslate" X="-100" />
                        </Rectangle.RenderTransform>
                    </Rectangle>
                </Grid>
            </Border>
        </Grid>
    </Border>
</Window>
