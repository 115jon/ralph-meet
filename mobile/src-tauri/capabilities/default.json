{
  "$schema": "../gen/schemas/mobile-schema.json",
  "identifier": "default",
  "description": "Default capabilities for the Ralph Meet mobile client",
  "windows": [
    "main"
  ],
  "permissions": [
    "core:default",
    "core:window:allow-close",
    "process:default",
    "shell:allow-open",
    "deep-link:default",
    "opener:default",
    "notification:default",
    "edge-to-edge:allow-enable",
    "edge-to-edge:allow-get-safe-area-insets",
    "status-bar-color:default"
  ]
}
