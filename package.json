{
  "name": "ralph-meet",
  "version": "0.1.0",
  "private": true,
  "scripts": {
    "dev": "next dev",
    "dev:all": "concurrently -n \"next,wrangler\" -c \"blue,yellow\" \"next dev\" \"wrangler dev --var NEXT_DEV_PROXY_URL:http://localhost:3000\"",
    "build": "next build",
    "build:worker": "npx @opennextjs/cloudflare build",
    "build:debug": "next build --webpack",
    "build:worker:debug": "npm run build:debug && npx @opennextjs/cloudflare build --skipBuild --noMinify",
    "preview": "npx wrangler dev",
    "deploy": "npx @opennextjs/cloudflare build && npx wrangler deploy",
    "start": "next start",
    "lint": "eslint",
    "test": "vitest run",
    "test:watch": "vitest",
    "test:coverage": "vitest run --coverage",
    "doctor": "npx -y react-doctor@latest . --verbose"
  },
  "dependencies": {
    "@clerk/nextjs": "^6.37.3",
    "@clerk/themes": "^2.4.51",
    "@dnd-kit/core": "^6.3.1",
    "@dnd-kit/sortable": "^10.0.0",
    "@dnd-kit/utilities": "^3.2.2",
    "@opennextjs/cloudflare": "^1",
    "class-variance-authority": "^0.7.1",
    "clsx": "^2.1.1",
    "cmdk": "^1.1.1",
    "date-fns": "^4.1.0",
    "lucide-react": "^0.564.0",
    "next": "16.1.6",
    "next-themes": "^0.4.6",
    "radix-ui": "^1.4.3",
    "react": "19.2.3",
    "react-dom": "19.2.3",
    "svix": "^1.85.0",
    "tailwind-merge": "^3.4.0",
    "zod": "^4.3.6",
    "zustand": "^5.0.11"
  },
  "devDependencies": {
    "@cloudflare/vitest-pool-workers": "^0.12.14",
    "@cloudflare/workers-types": "^4.20260214.0",
    "@tailwindcss/postcss": "^4.1.18",
    "@types/node": "^20",
    "@types/react": "^19",
    "@types/react-dom": "^19",
    "concurrently": "^9.2.1",
    "eslint": "^9",
    "eslint-config-next": "16.1.6",
    "postcss": "^8.5.6",
    "shadcn": "^3.8.4",
    "tailwindcss": "^4.1.18",
    "tw-animate-css": "^1.4.0",
    "typescript": "^5",
    "vitest": "^4.0.18",
    "wrangler": "^4"
  }
}