{
  "$schema": "https://raw.githubusercontent.com/googleapis/release-please/main/schemas/config.json",
  "bootstrap-sha": "6c803ac08a0633119ead1e6d8b5d8e791d260298",
  "packages": {
    ".": {
      "release-type": "node",
      "include-component-in-tag": false,
      "extra-files": [
        "desktop/package.json",
        "packages/kova-react/package.json",
        "mobile/package.json",
        {
          "type": "json",
          "path": "desktop/src-tauri/tauri.conf.json",
          "jsonpath": "$.version"
        },
        {
          "type": "toml",
          "path": "desktop/src-tauri/Cargo.toml",
          "jsonpath": "$.package.version"
        },
        {
          "type": "xml",
          "path": "desktop/installer/installer.csproj",
          "xpath": "//Project/PropertyGroup/Version"
        },
        {
          "type": "json",
          "path": "mobile/src-tauri/tauri.conf.json",
          "jsonpath": "$.version"
        },
        {
          "type": "toml",
          "path": "mobile/src-tauri/Cargo.toml",
          "jsonpath": "$.package.version"
        }
      ]
    }
  }
}
